{
  "name": "MediSync",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build --prefix frontend",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm start",
    "client": "cd frontend && npm run dev",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js --testPathPattern='unit'",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js --testPathPattern='integration'",
    "test:security": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js --testPathPattern='security'",
    "test:ux": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js --testPathPattern='ux'",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js --coverage",
    "test:incomplete": "node --experimental-vm-modules node_modules/.bin/jest --config tests/jest.config.js tests/ux/completeness/incomplete-services.test.js --verbose",
    "test:report": "node tests/reports/generate.js",
    "report:open": "node tests/reports/generate.js && xdg-open tests/reports/index.html 2>/dev/null || open tests/reports/index.html 2>/dev/null || echo 'Open tests/reports/index.html in your browser'"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prisma": "^7.8.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "babel-jest": "^29.7.0",
    "@babel/preset-env": "^7.26.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "pg": "^8.21.0"
  }
}
