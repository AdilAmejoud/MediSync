# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories (root, frontend, backend, microservices)
node_modules/
frontend/node_modules/
backend/node_modules/
backend/src/services/*/node_modules/

# Build directories (frontend build output)
dist/
frontend/dist/
frontend/dist-ssr/

# Build directories for potential backend build (if transpiling)
backend/dist/
backend/build/

# Environment files (root, frontend, backend, microservices)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
backend/.env
backend/src/services/*/.env

# Angular cache
frontend/.angular/

# Uploads (generated at runtime)
backend/src/uploads/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore coverage reports (if you're using coverage tools like Jest or Istanbul)
coverage/
frontend/coverage/
backend/coverage/

# Ignore temporary files like OS-generated files
*.tmp
*.swp

# Ignore generated test reports
tests/reports/index.html
tests/reports/raw.json

# Ignore Replit configuration files
.replitscripts/
