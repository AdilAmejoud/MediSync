# ─────────────────────────────────────────
# MediSync — Environment Variables Template
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── Backend ───────────────────────────────
NODE_ENV=development
PORT=3000


# JWT
JWT_SECRET=your_jwt_secret_key_here

# Admin credentials
ADMIN_EMAIL=admin@medisync.com
ADMIN_PASSWORD=admin_password_here

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Frontend ──────────────────────────────
# Angular reads from src/environments/environment.ts
# Update the apiUrl there to match your backend URL.

# ── Database (Future PostgreSQL) ──────────
# DATABASE_URL=postgresql://user:password@localhost:5432/medisync

# ── Resend (Email) ─────────────────────────
# RESEND_API_KEY=your_resend_api_key_here

